{
  "model": {
    "type": "minecraft:select",
    "cases": [
      {
        "model": {
          "type": "minecraft:model",
          "model": "evanpack:item/shield_item_frame"
        },
        "when": "fixed"
      }
    ],
    "fallback": {
      "type": "minecraft:condition",
