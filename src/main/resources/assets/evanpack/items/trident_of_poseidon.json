{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:display_context",
    "cases": [
      {
        "when": [
          "gui",
          "ground",
          "fixed",
          "on_shelf"
        ],
        "model": {
          "type": "minecraft:model",
          "model": "evanpack:item/trident_of_poseidon"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:condition",
      "property": "minecraft:using_item",
      "on_false": {
        "type": "minecraft:special",
        "base": "evanpack:item/trident_of_poseidon_in_hand",
        "model": {
          "type": "minecraft:trident"
        }
      },
      "on_true": {
        "type": "minecraft:special",
        "base": "evanpack:item/trident_of_poseidon_throwing",
        "model": {
          "type": "minecraft:trident"
        }
      }
    }
  }
}
