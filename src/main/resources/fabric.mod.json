{
	"schemaVersion": 1,
	"id": "artifacts",
	"version": "${version}",
	"name": "Fourth Wall Artifacts",
	"description": "Artifacts for the Fourth Wall SMP",
	"authors": [
		"daileta"
	],
	"contact": {
		"sources": "https://github.com/FabricMC/fabric-example-mod"
